# OpenAI API Key (primary LLM)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (fallback LLM)
GOOGLE_API_KEY=your_gemini_api_key_here

# Ollama config (automatic fallback if no API keys are set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# JWT Authentication
JWT_SECRET=shiproute-ai-change-this-to-a-random-secret

# SMTP for MFA OTP emails (optional - OTP prints to console if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# Server config
HOST=0.0.0.0
PORT=8000
